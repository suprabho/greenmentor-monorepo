{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "esg-agents/agents/data-validation/io.schema.json",
  "title": "DataValidationAgentIO",
  "$defs": {
    "Evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "row_ref": { "type": "string", "description": "dataset_row id." },
        "source_snippet": { "type": ["string", "null"] }
      },
      "required": ["row_ref"]
    },
    "Issue": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issue_id": { "type": "string" },
        "metric_code": { "type": "string" },
        "site_id": { "type": ["string", "null"] },
        "row_ref": { "type": ["string", "null"] },
        "check": {
          "type": "string",
          "enum": ["completeness", "accuracy", "methodology", "unit_integrity", "reconciliation", "consistency", "yoy", "outlier", "gap"]
        },
        "finding": { "type": "string" },
        "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
        "suggested_fix": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/Evidence" } },
        "route_to_human": { "type": "boolean", "default": false }
      },
      "required": ["issue_id", "metric_code", "check", "finding", "severity", "suggested_fix", "confidence"]
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenant_id": { "type": "string" },
        "engagement_id": { "type": "string" },
        "financial_year": { "type": "string" },
        "metric_defs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "label": { "type": "string" },
              "required_unit": { "type": ["string", "null"] },
              "is_required": { "type": "boolean", "default": true },
              "materiality": { "type": "string", "enum": ["high", "medium", "low"], "default": "medium" },
              "approved_methodology": { "type": ["string", "null"], "description": "e.g. 'location-based grid electricity; gross CV fuel'." },
              "recon_tolerance_pct": { "type": "number", "default": 5 },
              "yoy_alert_pct": { "type": "number", "default": 30 },
              "reconciles_with": { "type": ["array", "null"], "items": { "type": "string" }, "description": "metric_codes that must agree." }
            },
            "required": ["metric_code"]
          }
        },
        "dataset_rows": {
          "type": "array",
          "description": "Steward-accepted rows from Phase 4 (collection output shape).",
          "items": { "type": "object" }
        },
        "prior_year_values": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": "string" },
              "value": { "type": ["number", "null"] },
              "unit": { "type": ["string", "null"] }
            },
            "required": ["metric_code", "site_id"]
          }
        },
        "cross_source_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": "string" },
              "source_a_row_ref": { "type": "string" },
              "source_b_row_ref": { "type": "string" }
            },
            "required": ["metric_code", "source_a_row_ref", "source_b_row_ref"]
          }
        }
      },
      "required": ["tenant_id", "engagement_id", "financial_year", "metric_defs", "dataset_rows"]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": { "type": "string", "enum": ["pass", "pass_with_warnings", "fail"] },
        "data_quality_score": { "type": "number", "minimum": 0, "maximum": 100 },
        "check_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "check": { "type": "string" },
              "scope": { "type": "string", "description": "metric/site/period scope of this check." },
              "status": { "type": "string", "enum": ["pass", "warn", "fail", "not_applicable"] },
              "detail": { "type": ["string", "null"] }
            },
            "required": ["check", "status"]
          }
        },
        "issues": { "type": "array", "items": { "$ref": "#/$defs/Issue" } },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": ["string", "null"] },
              "reason": { "type": "string" }
            },
            "required": ["metric_code", "reason"]
          }
        },
        "yoy_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": ["string", "null"] },
              "current": { "type": ["number", "null"] },
              "prior": { "type": ["number", "null"] },
              "yoy_change_pct": { "type": ["number", "null"] },
              "flagged": { "type": "boolean", "default": false }
            },
            "required": ["metric_code"]
          }
        },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "human_queue": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "issue_id": { "type": "string" },
              "why": { "type": "string" }
            },
            "required": ["issue_id", "why"]
          }
        },
        "data_owner_queries": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "issue_id": { "type": "string" },
              "data_owner": { "type": "string" },
              "question": { "type": "string" }
            },
            "required": ["issue_id", "question"]
          }
        }
      },
      "required": ["verdict", "data_quality_score", "check_results", "issues"]
    }
  }
}
