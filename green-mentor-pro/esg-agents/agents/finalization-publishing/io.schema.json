{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "esg-agents/agents/finalization-publishing/io.schema.json",
  "title": "FinalizationPublishingIO",
  "$defs": {
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenant_id": { "type": "string" },
        "engagement_id": { "type": "string" },
        "report_sections": { "type": "array", "items": { "type": "object" } },
        "calc_result": { "type": "object" },
        "signoffs": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["tenant_id", "engagement_id", "report_sections"]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "final_sections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "section_id": { "type": "string" },
              "title": { "type": "string" },
              "body_markdown": { "type": "string" }
            },
            "required": ["section_id", "body_markdown"]
          }
        },
        "consistency_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "where": { "type": "string" },
              "finding": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "warning", "error"] }
            },
            "required": ["where", "finding", "severity"]
          }
        },
        "investor_summary": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "headline_metrics": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "label": { "type": "string", "description": "Metric name, e.g. 'Scope 1+2 emissions'" },
                  "value": { "type": ["string", "number"], "description": "Reported value" },
                  "unit": { "type": ["string", "null"], "description": "e.g. 'tCO2e', 'kWh', '%'" },
                  "period": { "type": ["string", "null"], "description": "Reporting period, e.g. 'FY2025-26'" },
                  "yoy_change": { "type": ["string", "null"], "description": "Year-over-year change, e.g. '-12%'" }
                },
                "required": ["label", "value"]
              }
            },
            "highlights": { "type": "array", "items": { "type": "string" } }
          }
        },
        "publication_checklist": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "item": { "type": "string" },
              "done": { "type": "boolean" }
            },
            "required": ["item", "done"]
          }
        }
      },
      "required": ["final_sections", "publication_checklist"]
    }
  }
}
