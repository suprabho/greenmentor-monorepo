[
  {
    "name": "emit_validation_report",
    "description": "Return the full data-quality validation report: a verdict, a quality score, every check result, the issues[] with severity/suggested_fix/confidence, gaps, the YoY summary, and documented assumptions/limitations. Call exactly once.",
    "strict": true,
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "verdict": { "type": "string", "enum": ["pass", "pass_with_warnings", "fail"] },
        "data_quality_score": { "type": "number" },
        "check_results": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "check": { "type": "string", "enum": ["completeness", "accuracy", "methodology", "unit_integrity", "reconciliation", "consistency", "yoy", "outlier", "gap"] },
              "scope": { "type": "string" },
              "status": { "type": "string", "enum": ["pass", "warn", "fail", "not_applicable"] },
              "detail": { "type": ["string", "null"] }
            },
            "required": ["check", "status"]
          }
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "issue_id": { "type": "string" },
              "metric_code": { "type": "string" },
              "site_id": { "type": ["string", "null"] },
              "row_ref": { "type": ["string", "null"] },
              "check": { "type": "string", "enum": ["completeness", "accuracy", "methodology", "unit_integrity", "reconciliation", "consistency", "yoy", "outlier", "gap"] },
              "finding": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
              "suggested_fix": { "type": "string" },
              "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
              "evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "row_ref": { "type": "string" },
                    "source_snippet": { "type": ["string", "null"] }
                  },
                  "required": ["row_ref"]
                }
              },
              "route_to_human": { "type": "boolean" }
            },
            "required": ["issue_id", "metric_code", "check", "finding", "severity", "suggested_fix", "confidence"]
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": ["string", "null"] },
              "reason": { "type": "string" }
            },
            "required": ["metric_code", "reason"]
          }
        },
        "yoy_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "metric_code": { "type": "string" },
              "site_id": { "type": ["string", "null"] },
              "current": { "type": ["number", "null"] },
              "prior": { "type": ["number", "null"] },
              "yoy_change_pct": { "type": ["number", "null"] },
              "flagged": { "type": "boolean" }
            },
            "required": ["metric_code"]
          }
        },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "human_queue": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "issue_id": { "type": "string" },
              "why": { "type": "string" }
            },
            "required": ["issue_id", "why"]
          }
        }
      },
      "required": ["verdict", "data_quality_score", "check_results", "issues"]
    }
  },
  {
    "name": "raise_data_owner_query",
    "description": "Queue a precise question back to a data owner to resolve a specific validation issue (missing data, YoY swing, reconciliation gap). One call per query.",
    "strict": true,
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "issue_id": { "type": "string" },
        "data_owner": { "type": "string" },
        "metric_code": { "type": "string" },
        "site_id": { "type": ["string", "null"] },
        "question": { "type": "string", "description": "A single, answerable question with the specific value/period in question." },
        "needs_evidence": { "type": "boolean", "description": "True if a supporting document is required to close the issue." }
      },
      "required": ["issue_id", "data_owner", "question"]
    }
  }
]
