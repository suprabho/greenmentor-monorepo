[
  {
    "name": "build_questionnaire",
    "description": "Generate a sector-relevant double-materiality questionnaire across candidate E/S/G topics for internal and external stakeholders.",
    "strict": true,
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sector": { "type": "string" },
        "candidate_topics": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["sector"]
    }
  },
  {
    "name": "score_materiality",
    "description": "Score one topic on impact and financial significance (0-5 each) with a rationale and the likely disclosures it drives.",
    "strict": true,
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "topic_id": { "type": "string" },
        "impact_score": { "type": "number" },
        "financial_score": { "type": "number" },
        "rationale": { "type": "string" }
      },
      "required": ["topic_id", "impact_score", "financial_score", "rationale"]
    }
  },
  {
    "name": "emit_materiality_matrix",
    "description": "Return the materiality artifact (questionnaire?, scored_topics, material_topics, threshold). Call exactly once.",
    "strict": true,
    "input_schema": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "questionnaire": { "type": ["array", "null"], "items": { "type": "object" } },
        "scored_topics": { "type": "array", "items": { "type": "object" } },
        "material_topics": { "type": "array", "items": { "type": "object" } },
        "materiality_threshold": { "type": "number" }
      },
      "required": ["scored_topics", "material_topics"]
    }
  }
]
