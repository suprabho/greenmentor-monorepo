# Shared GreenMentor Supabase project (same project as community-engine).
# Anon key is browser-safe; access enforced by RLS.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — service role for agent runs / cross-tenant orchestrator writes.
# NEVER expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — powers every agent (strict tool-use calls).
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — ESG Buddy chat routes through the Vercel AI Gateway with this key
# (one key → many providers, with failover + spend monitoring). On Vercel, OIDC can
# replace it. Override the model with AI_GATEWAY_MODEL (default anthropic/claude-sonnet-4.5).
AI_GATEWAY_API_KEY=vck_xxxxxxxxxxxxxxxxxxxxxxxx
# AI_GATEWAY_MODEL=anthropic/claude-sonnet-4.5

# Model overrides (optional). Defaults live in lib/anthropic/models.ts.
ANTHROPIC_MODEL_OPUS=claude-opus-4-8
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5

# EFDB creds (EFDB_API_URL / EFDB_EMAIL / EFDB_PASSWORD) — used by the calculation
# agent (search_emission_factors). These are shared with the platform app and live
# in green-mentor-pro/.env.shared (see .env.shared.example), loaded by next.config.ts.
# In production set them in the deployment's env (they override the shared file).

# Storage bucket for evidence/uploads (per-engagement, tenant-scoped via RLS).
ESG_STORAGE_BUCKET=esg-evidence

# Deployment mode: cloud_hosted | self_hosted (gates theming source + channel registry).
ESG_DEPLOYMENT_MODE=cloud_hosted

# ---- Legacy GreenMentor identity + data services (server-only, no NEXT_PUBLIC_) ----
# Per-user auth pass-through: users sign in with their greenmentor-in-um credentials;
# that JWT scopes their org. All -um / -be calls are server-to-server (no CORS).
UM_API_URL=https://greenmentor-in-um.fly.dev/api/v1   # identity service (login/refresh/logout)
BE_API_URL=https://greenmentor-in-be.fly.dev/api/v1   # legacy BRSR data API (optional grounding reads)

# Encrypts the session cookie that seals the -um tokens. Use a long random string
# (>=32 chars). Rotating it invalidates all sessions.
SESSION_SECRET=change-me-to-a-long-random-32+char-secret
# Optional override for the session cookie name.
# SESSION_COOKIE_NAME=gm_session
