# Shared server-side config for the green-mentor-pro apps (platform + esg-agents).
# Copy to `.env.shared` and fill in. Loaded at startup by each app's
# next.config.ts (process.loadEnvFile); real env (shell / Vercel / Fly) wins, so
# set these in the deployment's env for production.

# EFDB — emission-factor lookup (consulting/efdb FastAPI). Production backend is
# the efdb-api Fly app; point at a local instance for offline dev.
EFDB_API_URL=https://efdb-api.fly.dev
EFDB_EMAIL=
EFDB_PASSWORD=
