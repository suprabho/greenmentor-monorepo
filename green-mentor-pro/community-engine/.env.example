# Shared GreenMentor Supabase project.
# The publishable (anon) key is designed to be exposed to the browser; real
# access is enforced by Row-Level Security. Copy this file to .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://haokazwcljdummkvufcg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — powers the Header Studio "Draft with AI" button (Claude Haiku).
# Never expose this to the browser (no NEXT_PUBLIC_ prefix). Optional: the
# studio works without it; the AI draft button just returns a 500.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Admin hub allowlist. Comma-separated; an entry starting with `@` matches a
# whole domain. The dashboard at `/` and every admin section are gated to these
# emails — fails CLOSED, so unset means nobody is an admin (non-admins are sent
# to /library). Every signed-in user can still use the maker tools.
ADMIN_ALLOWED_EMAILS=@promad.design,@greenmentor.co
