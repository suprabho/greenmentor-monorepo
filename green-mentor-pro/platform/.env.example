# Shared GreenMentor Supabase project (haokazwcljdummkvufcg).
# The publishable (anon) key is designed to be exposed to the browser; real
# access is enforced by Row-Level Security. Copy this file to .env.local.
NEXT_PUBLIC_SUPABASE_URL=https://haokazwcljdummkvufcg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — bypasses RLS. Required for:
#   • the Academy API routes (app/api/academy/**) — signed video URLs,
#     watch-progress writes, assessment scoring, XP/coin/streak awards
#     (progress + gamification tables have no client write policies at all)
#   • scripts/seed-academy-media.ts (npm run academy:seed-media)
#   • scripts/ingest-feed.ts (npm run feed:ingest)
# Never expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# Server-only — powers the AI Hub agents, ESG Buddy chat, and the feed
# ingestion worker's summarizer. Optional for the Academy loop.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────

# Feed ingestion worker tuning (scripts/ingest-feed.ts).
# FEED_SUMMARY_MODEL=claude-haiku-4-5
# FEED_PER_SOURCE=6

# Marketing site: links out to the legacy Learnyst-hosted course catalog and
# the flat-discount banner. Defaults are baked in; override only if they move.
# NEXT_PUBLIC_LEARNYST_BASE_URL=https://academy.greenmentor.co
# NEXT_PUBLIC_LEARNYST_CATALOG_URL=https://academy.greenmentor.co/learn
# NEXT_PUBLIC_FLAT_DISCOUNT_INR=500

# EFDB — emission-factor lookup for the Energy module (lib/energy/factors.ts, via
# @gm/orchestrator). Shared with esg-agents; the creds (EFDB_API_URL / EFDB_EMAIL /
# EFDB_PASSWORD) live in green-mentor-pro/.env.shared (see .env.shared.example),
# loaded by next.config.ts. In production set them in the deployment's env.
