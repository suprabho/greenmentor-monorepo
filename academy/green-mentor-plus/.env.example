# ── Learnyst (existing) ───────────────────────────────────────────────────────
# Override when pointing at a staging school. Defaults to production.
NEXT_PUBLIC_LEARNYST_BASE_URL=https://learn.greenmentor.academy

# ── Razorpay (payment seam) ───────────────────────────────────────────────────
# 1) Create a test-mode account and grab the API keys from:
#    https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_**************
RAZORPAY_KEY_SECRET=**************

# Same KEY_ID exposed to the browser so the Razorpay Checkout SDK can init.
# NEVER expose KEY_SECRET — only the public key id.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_**************

# 2) Create a webhook in the dashboard pointed at
#    https://<your-host>/api/razorpay/webhook
#    Subscribe to: subscription.activated, subscription.charged,
#    subscription.cancelled, subscription.halted, subscription.completed,
#    payment.failed. Copy the webhook secret here.
RAZORPAY_WEBHOOK_SECRET=**************

# 3) Create two Razorpay plans (Subscriptions → Plans → Create plan) — one
#    monthly, one annual — at the amounts in lib/data/plans.ts (₹2,499/mo and
#    ₹1,999/mo billed yearly = ₹23,988/yr). Copy each `plan_…` id here.
#    Naming convention: RAZORPAY_PLAN_<UPPERCASE_PLAN_ID>_<MONTHLY|ANNUAL>
RAZORPAY_PLAN_MEMBERSHIP_MONTHLY=plan_**************_MONTHLY
RAZORPAY_PLAN_MEMBERSHIP_ANNUAL=plan_**************_ANNUAL

# 4) Offers / promo codes (lib/razorpay/promos.ts). Each registry entry names
#    the env var holding its Razorpay `offer_…` id (Subscriptions → Offers).
#    An entry with `autoApply` is attached automatically (no code to type);
#    others require the user to enter the code. When an env var is unset, that
#    offer is silently skipped, so the app still runs without it.
#    These two power the auto-applied flat ₹2,000 launch discount — one per
#    cycle, since Razorpay offers are plan-specific. Each offer's discount must
#    equal `flatDiscount.discountInr` in lib/data/plans.ts.
RAZORPAY_OFFER_WELCOME20=offer_**************       # monthly — first month −₹2,000
RAZORPAY_OFFER_LAUNCH_ANNUAL=offer_**************   # annual  — first year  −₹2,000

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement id. When unset, GA + page-view tracking are
# skipped entirely (handy locally).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-**************

# Meta (Facebook) Pixel id. Grab it from Events Manager → Data Sources. When
# unset, the pixel script and page-view tracking are skipped.
NEXT_PUBLIC_META_PIXEL_ID=**************

# ── Lead sheet (Google Sheets via Apps Script) ────────────────────────────────
# Onboarding leads are upserted into a Google Sheet through an Apps Script web
# app — no service account, no IAM key, no JSON credentials. See
# docs/lead-sheet-setup.md for the one-time setup (paste a script into the
# sheet, deploy it as a web app, copy the /exec URL here). When SHEETS_WEBHOOK_URL
# is unset, /api/lead just logs to the console instead of writing (handy locally).
#
# The Apps Script web-app deployment URL (ends in /exec).
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/**************/exec
# Optional shared secret. Set the SAME random string here and as SHARED_SECRET
# in the Apps Script; leave blank on both to disable the check.
SHEETS_WEBHOOK_SECRET=**************
