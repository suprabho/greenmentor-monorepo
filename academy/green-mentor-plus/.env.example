# ── Learnyst (existing) ───────────────────────────────────────────────────────
# Override when pointing at a staging school. Defaults to production.
NEXT_PUBLIC_LEARNYST_BASE_URL=https://learn.greenmentor.academy

# ── Razorpay (payment seam) ───────────────────────────────────────────────────
# 1) Create a test-mode account and grab the API keys from:
#    https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_**************
RAZORPAY_KEY_SECRET=**************

# Same KEY_ID exposed to the browser so the Razorpay Checkout SDK can init.
# NEVER expose KEY_SECRET — only the public key id.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_**************

# 2) Create a webhook in the dashboard pointed at
#    https://<your-host>/api/razorpay/webhook
#    Subscribe to: subscription.activated, subscription.charged,
#    subscription.cancelled, subscription.halted, subscription.completed,
#    payment.failed. Copy the webhook secret here.
RAZORPAY_WEBHOOK_SECRET=**************

# 3) Create two Razorpay plans (Subscriptions → Plans → Create plan) — one
#    monthly, one annual — at the amounts in lib/data/plans.ts (₹2,499/mo and
#    ₹1,999/mo billed yearly = ₹23,988/yr). Copy each `plan_…` id here.
#    Naming convention: RAZORPAY_PLAN_<UPPERCASE_PLAN_ID>_<MONTHLY|ANNUAL>
RAZORPAY_PLAN_MEMBERSHIP_MONTHLY=plan_**************_MONTHLY
RAZORPAY_PLAN_MEMBERSHIP_ANNUAL=plan_**************_ANNUAL

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Analytics 4 measurement id. When unset, GA + page-view tracking are
# skipped entirely (handy locally).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-**************

# Meta (Facebook) Pixel id. Grab it from Events Manager → Data Sources. When
# unset, the pixel script and page-view tracking are skipped.
NEXT_PUBLIC_META_PIXEL_ID=**************

# ── Lead sheet (Google Sheets via service account) ────────────────────────────
# Onboarding leads are upserted into a Google Sheet directly via the Sheets API
# — no Apps Script web app. See docs/lead-sheet-setup.md for the one-time setup
# (create a service account, enable the Sheets API, share the sheet with the
# service-account email as Editor). When any of these is unset, /api/lead just
# logs to the console instead of writing (handy locally).
#
# Service-account email (…@….iam.gserviceaccount.com) from the JSON key file.
GOOGLE_SHEETS_CLIENT_EMAIL=**************@**************.iam.gserviceaccount.com
# The PEM private_key from the JSON key, as a single line with literal \n for
# newlines (wrap the whole value in double quotes).
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n**************\n-----END PRIVATE KEY-----\n"
# The spreadsheet id — the long token in the sheet URL between /d/ and /edit.
GOOGLE_SHEETS_SPREADSHEET_ID=**************
