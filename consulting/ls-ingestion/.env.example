# ── Database (EFDB backend) ───────────────────────────────────────
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
DATABASE_URL_SYNC=

# ── Auth ──────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Anthropic ─────────────────────────────────────────────────────
# Server-side only — injected by vite proxy, never sent to browser.
# Do NOT prefix with VITE_ (that would expose it in the client bundle).
ANTHROPIC_API_KEY=

# ── Supabase (browser) ────────────────────────────────────────────
# Exposed to the client bundle (VITE_ prefix) — anon key only, never the service-role key.
# Get these from the Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Confidence score floor ────────────────────────────────────────
CHAT_CONFIDENCE_FLOOR=60

# ── File storage ──────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
