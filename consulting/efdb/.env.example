# Database — Supabase session pooler (asyncpg for the app, sync for Alembic)
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
DATABASE_URL_SYNC=postgresql+psycopg2://postgres.<project-ref>:<password>@<pooler-host>:5432/postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=efdb

# Auth (backend-issued JWTs)
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Supabase Auth (Google OAuth) — leave empty to disable Google sign-in.
# The anon key is the public/publishable key from the Supabase dashboard.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
# Same values again for the Vite frontend (build/dev time).
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=

# Anthropic (extraction + chat)
ANTHROPIC_API_KEY=

# Chat
CHAT_CONFIDENCE_FLOOR=60

# Uploads
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=100
